# =====================================================================
# SACPROMI BACKEND — variables d'environnement
# =====================================================================
# Copiez ce fichier en `.env` pour le développement local.
# Sur Railway, configurez ces variables dans l'onglet "Variables" du projet.
# =====================================================================

# --- Application -----------------------------------------------------
NODE_ENV=development                       # development | production
PORT=3070                                  # ignoré sur Railway (PORT injecté)
TZ=Africa/Dakar                            # fuseau horaire — laisser tel quel

# --- Base de données -------------------------------------------------
# En local : postgres://postgres:passer@localhost:5432/sacpromi?schema=public
# Sur Railway : utilisez la variable injectée ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sacpromi?schema=public"

# --- Authentification JWT --------------------------------------------
# IMPORTANT : générez des secrets robustes en prod :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="change-this-access-secret-in-production"
JWT_ACCESS_EXPIRATION="24h"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_REFRESH_EXPIRATION="7d"

# --- Sécurité --------------------------------------------------------
BCRYPT_SALT_ROUNDS=12                      # ne pas descendre sous 10

# --- CORS ------------------------------------------------------------
# En prod : indiquez l'URL de votre frontend Vercel (séparées par virgule)
# Exemple : "https://sacpromi.vercel.app,https://sacpromi-staging.vercel.app"
CORS_ORIGIN="http://localhost:3071"

# --- URL frontend (utilisée dans les emails) -------------------------
# Lien reset-password, lien des factures envoyées par email, etc.
APP_URL=http://localhost:3071

# --- Mailer (Nodemailer SMTP) ----------------------------------------
# Si MAIL_HOST n'est pas défini, le service utilise jsonTransport (logs only).
# En prod, recommandé : Brevo, Mailtrap, SendGrid, ou Gmail (mot de passe d'application)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true                           # true pour port 465, false pour 587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="SACPROMI <noreply@sacpromi.sn>"

# --- Sauvegarde PG (optionnel, scripts dans /scripts) ---------------
# BACKUP_DIR=/var/backups/sacpromi
# BACKUP_RETENTION_DAYS=30
